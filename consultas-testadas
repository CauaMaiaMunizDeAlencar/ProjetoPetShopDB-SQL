  -- Primeira consulta: Vendas e seus respectivos clientes.
SELECT v.venda_id, v.data_e_hora, v.valor_total, c.nome
FROM venda v, cliente c 
WHERE c.cpf = v.cpf_cliente;

-- Segunda consulta: Evolução da primeira mas mostrando os clientes NULL
SELECT v.venda_id, v.data_e_hora, v.valor_total, c.nome	
FROM venda v
LEFT JOIN cliente c ON v.cpf_cliente = c.cpf; -- Retorna os clientes mesmo que não tenha um correspondente.

 -- Terceira consulta: Retorna os codigos de barras das compras que fazem parte da venda de ID 1
SELECT co.codigo_de_barras, p.nome, p.preco, co.quantidade
FROM contem AS co, produto p
WHERE co.codigo_de_barras = p.codigo_de_barras AND co.venda_id = 1;

 -- Quarta consulta: Igual a segunda consulta mas utilizando um join para alterá-la
SELECT co.codigo_de_barras, p.nome, p.preco, co.quantidade
FROM contem AS co
JOIN produto p ON p.codigo_de_barras = co.codigo_de_barras
WHERE co.venda_id = 1;

 -- Quinta consulta: Produtos fornecidos por um fornecedor
SELECT p.nome
FROM fornece f
JOIN produto p ON f.codigo_de_barras = p.codigo_de_barras
WHERE f.cnpj = '43.827.195/0001-81';

 -- Sexta consulta: Total de itens vendidos por produtos, exemplo de uso group by
SELECT p.nome, SUM(c.quantidade) AS total_vendido	
FROM contem c
JOIN produto p ON c.codigo_de_barras = p.codigo_de_barras
GROUP BY p.nome;

 -- Sétima consulta: Produtos mais vendidos exemeplo de uso order by, poderia ser crescente ou decrescente
SELECT p.nome, SUM(c.quantidade) AS total
FROM contem c
JOIN produto p ON c.codigo_de_barras = p.codigo_de_barras
GROUP BY p.nome
ORDER BY total DESC;

 -- Oitava consulta: Quantidade total de vendas, valor médio das vendas, maior valor de uma venda, total bruto de vendas
SELECT count(*) AS total_vendas
FROM venda;
SELECT avg(valor_total) AS media_venda
FROM venda;
SELECT max(valor_total) AS maior_venda
FROM venda;
SELECT sum(valor_total) AS total_bruto
FROM venda;

 -- Nona consulta: Total de valor vendido em um dia
SELECT SUM(valor_total) AS valor_total
FROM venda 
WHERE data_e_hora BETWEEN '2025-01-11 00:00:00'
AND '2025-01-14 23:59:59';

SELECT c.nome
FROM cliente c
WHERE c.nome LIKE 'M%';
